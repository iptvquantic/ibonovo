<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:background="@drawable/card_bg"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp">

    <FrameLayout android:layout_width="110dp" android:layout_height="66dp"
        android:layout_marginEnd="14dp">
        <ImageView android:id="@+id/ivThumb"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:scaleType="centerCrop" android:background="@color/bg_card2"/>
        <Button android:id="@+id/btnPlay"
            android:layout_width="32dp" android:layout_height="32dp"
            android:layout_gravity="center"
            android:background="@drawable/btn_play_bg"
            android:text="▶" android:textColor="@color/bg_dark" android:textSize="12sp"
            android:padding="0dp"/>
    </FrameLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/tvEpNum"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/brand_primary" android:textSize="12sp" android:textStyle="bold"
                android:background="@drawable/chip_bg_dark"
                android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="2dp" android:paddingBottom="2dp"
                android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/tvEpDuration"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="11sp"/>
        </LinearLayout>
        <TextView android:id="@+id/tvEpTitle"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold"
            android:layout_marginTop="4dp" android:ellipsize="end" android:maxLines="1"/>
        <TextView android:id="@+id/tvEpPlot"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="11sp"
            android:layout_marginTop="2dp" android:ellipsize="end" android:maxLines="2"/>
    </LinearLayout>
</LinearLayout>
