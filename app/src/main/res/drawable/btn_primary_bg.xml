<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#00CC33" android:endColor="#007722" android:angle="135"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#00FF41" android:endColor="#00CC33" android:angle="135"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#80FF41"/>
        </shape>
    </item>
</selector>
